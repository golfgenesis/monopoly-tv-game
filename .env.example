# Copy to .env and paste your real token. .env is gitignored — never commit it.
#
# Cloudflare Tunnel connector token:
#   Cloudflare Zero Trust → Networks → Tunnels → (your tunnel) → Configure → copy the
#   token from the `cloudflared ... run --token <TOKEN>` command.
TUNNEL_TOKEN=paste-your-cloudflare-tunnel-token-here
